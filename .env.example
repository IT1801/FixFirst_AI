# ---------------------------------------------------------------------------
# FixFirst AI — environment configuration
# Copy this file to .env and fill in real values. Never commit .env itself.
# ---------------------------------------------------------------------------

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=fixfirst
POSTGRES_PASSWORD=fixfirst
# URL-encode reserved URI characters in the password (for example, @ -> %40).
POSTGRES_PASSWORD_URLENCODED=fixfirst
POSTGRES_DB=fixfirst
# Local scripts connect through Docker's published host port. Compose
# overrides DB_HOST/DB_PORT for services running inside its network.
DB_HOST=localhost
DB_PORT=6543

# --- MLflow -------------------------------------------------------------
# Local scripts connect through the published MLflow port.
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=fixfirst-absa

# --- LLM fallback (silver labeling + low-confidence inference routing) ---
# Used for: (1) bootstrapping silver labels in Phase 3, (2) runtime fallback
# when the fine-tuned model's confidence falls below LLM_FALLBACK_THRESHOLD
LLM_PROVIDER=anthropic          # anthropic | openai | groq
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
LLM_MODEL_NAME=claude-sonnet-4-6
LLM_FALLBACK_THRESHOLD=0.65      # confidence below this routes to the LLM
LLM_MAX_REQUESTS_PER_MINUTE=30   # global cap shared by labeling workers

# --- App / API ---------------------------------------------------------
APP_ENV=development              # development | staging | production
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# --- Paths ---------------------------------------------------------------
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_SILVER_LABELS_DIR=data/silver_labels
DATA_GOLD_EVAL_DIR=data/gold_eval
MODEL_ARTIFACT_DIR=artifacts/models

DASHBOARD_API_BASE_URL=http://api:8000
